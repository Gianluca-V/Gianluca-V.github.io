---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import TechList from './TechList.astro';
import ShowcaseImage from './ShowcaseImage.astro';
import Icon from './Icon.astro';

const experiments = (await getCollection('experiments')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="experiments" class="mx-auto max-w-5xl px-4 py-20 sm:px-6" aria-label="Experiments">
  <SectionHeading
    eyebrow="experiments"
    title="Smaller projects, bigger curiosity"
    subtitle="Quick builds and curiosities — made to learn something new, or just for the fun of it."
  />

  <div class="grid gap-6 sm:grid-cols-2">
    {
      experiments.map((experiment) => (
        <article class="reveal group flex flex-col overflow-hidden rounded-xl border border-line bg-surface-raised transition-colors hover:border-accent/50">
          <div class="relative aspect-video overflow-hidden border-b border-line">
            <ShowcaseImage
              image={experiment.data.image}
              title={experiment.data.title}
              class="transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="flex grow flex-col p-5">
            <h3 class="text-lg font-bold text-fg">{experiment.data.title}</h3>
            <p class="mt-0.5 font-mono text-xs text-magenta">{experiment.data.tagline}</p>
            <p class="mt-3 text-sm leading-relaxed text-fg-muted">{experiment.data.description}</p>
            <TechList items={experiment.data.tech} class="mt-4" />
            <div class="mt-4 flex grow flex-wrap items-end gap-4">
              {experiment.data.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-soft transition-colors hover:text-magenta"
                >
                  {link.label}
                  <Icon name="external" class="h-3.5 w-3.5" />
                </a>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
