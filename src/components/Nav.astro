---
import { site } from '../data/site';

// Brand mark initials, e.g. "gv" for Gianluca Vespe.
const initials = site.owner
  .split(/\s+/)
  .map((word) => word[0])
  .join('')
  .toLowerCase();

const links = [
  { label: 'Home', href: '#home' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects', href: '#projects' },
  { label: 'Experiments', href: '#experiments' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-40 border-b border-line/60 bg-surface/80 backdrop-blur-md">
  <nav
    aria-label="Main navigation"
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3 sm:px-6"
  >
    <a
      href="#home"
      class="font-mono text-sm font-semibold tracking-tight text-fg transition-colors hover:text-accent-soft"
    >
      <span class="text-code-punct">&lt;</span><span class="text-magenta">{initials}</span>
      <span class="text-code-punct">/&gt;</span>
    </a>
    <ul class="flex items-center gap-1 overflow-x-auto text-sm sm:gap-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="block whitespace-nowrap rounded-md px-2.5 py-1.5 text-fg-muted transition-colors hover:bg-surface-overlay hover:text-fg sm:px-3"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
