---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-line/60">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-4 py-8 text-sm text-fg-faint sm:px-6"
  >
    <p>© {year} {site.owner}</p>
    <p class="font-mono">
      Built with <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-fg-muted transition-colors hover:text-accent-soft">Astro</a
      >
    </p>
  </div>
</footer>
