---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import TechList from './TechList.astro';

const jobs = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order
);

const formatRange = (start: string, end: string | null) =>
  end === null ? `${start} - Present` : start === end ? start : `${start} - ${end}`;
---

<section id="experience" class="mx-auto max-w-5xl px-4 py-20 sm:px-6" aria-label="Work experience">
  <SectionHeading eyebrow="experience" title="Where I've worked" />

  <ol class="relative ml-3 border-l border-line">
    {
      jobs.map((job) => (
        <li class="reveal relative pb-12 pl-8 last:pb-0">
          <span
            class="absolute top-1.5 -left-[7px] h-3.5 w-3.5 rounded-full border-2 border-surface bg-gradient-to-br from-accent to-magenta"
            aria-hidden="true"
          />
          <p class="font-mono text-sm text-fg-muted">
            {formatRange(job.data.startDate, job.data.endDate)}
          </p>
          <h3 class="mt-1 text-xl font-semibold text-fg">
            {job.data.role}
            <span class="text-fg-muted"> · {job.data.seniority}</span>
          </h3>
          <p class="font-medium text-accent-soft">{job.data.company}</p>
          <p class="mt-3 max-w-2xl leading-relaxed text-fg-muted">{job.data.summary}</p>
          <ul class="mt-3 max-w-2xl space-y-1.5 text-sm text-fg-muted">
            {job.data.highlights.map((highlight) => (
              <li class="flex gap-2">
                <span class="mt-0.5 text-magenta" aria-hidden="true">
                  ▹
                </span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
          <TechList items={job.data.tech} class="mt-4" />
        </li>
      ))
    }
  </ol>
</section>
