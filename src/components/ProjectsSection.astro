---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';
import TechList from './TechList.astro';
import ShowcaseImage from './ShowcaseImage.astro';
import Icon from './Icon.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<section id="projects" class="mx-auto max-w-5xl px-4 py-20 sm:px-6" aria-label="Featured projects">
  <SectionHeading eyebrow="projects" title="Featured work" />

  <div class="space-y-12">
    {
      projects.map((project) => (
        <article class="reveal group overflow-hidden rounded-2xl border border-line bg-surface-raised transition-colors hover:border-accent/50 lg:grid lg:grid-cols-[2fr_3fr]">
          <div class="relative min-h-56 overflow-hidden border-b border-line lg:min-h-full lg:border-r lg:border-b-0">
            <ShowcaseImage
              image={project.data.image}
              title={project.data.title}
              class="transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="p-6 sm:p-8">
            <h3 class="text-2xl font-bold text-fg">{project.data.title}</h3>
            <p class="mt-1 font-mono text-sm text-magenta">{project.data.tagline}</p>
            <p class="mt-4 leading-relaxed text-fg-muted">{project.data.description}</p>
            {project.data.highlights.length > 0 && (
              <ul class="mt-4 space-y-1.5 text-sm text-fg-muted">
                {project.data.highlights.map((highlight) => (
                  <li class="flex gap-2">
                    <span class="mt-0.5 text-accent-soft" aria-hidden="true">
                      ▹
                    </span>
                    <span>{highlight}</span>
                  </li>
                ))}
              </ul>
            )}
            <TechList items={project.data.tech} class="mt-5" />
            <div class="mt-6 flex flex-wrap gap-4">
              {project.data.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 font-semibold text-accent-soft transition-colors hover:text-magenta"
                >
                  {link.label}
                  <Icon name="external" class="h-4 w-4" />
                </a>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
